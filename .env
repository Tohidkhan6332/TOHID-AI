# ____REMOVE THIS LINE AFTER RENAMING sample.env to .env ____

# PUT YOUR SESSION ID BELOW
SESSION_ID=

# PUT YOUR REMOVE BACKGROUND API KEY BELOW
REMOVEBG_KEY=

PORT=5000

# If you don't have session id and want pairing code for connection 
PAIRING_NUMBER=917849917350


# Use One Of Following:
# Database Configuration (Optional but recommended)
# Leave empty to use JSON file storage

# MongoDB
MONGO_URL=

# PostgreSQL
POSTGRES_URL=

# MySQL
MYSQL_URL=

# SQLite (provide path only if you want to use SQLite)
# Example: DB_URL=./data/baileys.db
DB_URL=

PREFIXES=.,!,/

PACKNAME=𝐓𝐎𝐇𝐈𝐃-𝐀𝐈

BOT_NAME=𝐓𝐎𝐇𝐈𝐃-𝐀𝐈

OWNER_NUMBER=917849917350

COMMAND_MODE=private

MAX_STORE_MESSAGES=50

BOT_OWNER=𝕄𝕣 𝕋𝕠𝕙𝕚𝕕

TIMEZONE=Asia/Kolkata
